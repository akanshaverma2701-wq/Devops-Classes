        <mxCell id="LSxagZJ76Zj6Aq-rcaEQ-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6d8764;fontColor=#ffffff;strokeColor=#3A5431;" value="LRS (locally Redundant Storage)&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;all 3 copies in&lt;b&gt; the same data center&lt;/b&gt; of the same zone&amp;nbsp; but in the same region&amp;nbsp;&lt;/li&gt;&lt;li&gt;its saves our data from rack failures, disks failures, server failure but is only for non critical scenarios&amp;nbsp;&lt;/li&gt;&lt;li&gt;lowest cost option&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
